# AI Services (OBRIGATÓRIO)
OPENAI_API_KEY=your_openai_api_key_here

# Google Vertex AI (OBRIGATÓRIO) — Gemini calls route through Vertex
GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/service-account.json
VERTEX_PROJECT_ID=your_gcp_project_id
VERTEX_LOCATION=us-central1

# Google Fact Check Tools API key (still uses an API key, separate from Gemini auth)
GOOGLE_API_KEY=your_google_api_key_here

# Web Scraping (Apify) (OBRIGATÓRIO)
APIFY_TOKEN=your_apify_token_here

# Google Search (OBRIGATÓRIO)
GOOGLE_SEARCH_API_KEY=your_google_search_api_key
GOOGLE_CSE_CX=your_cse_cx_key


# Variáveis de ambiente para a conexão com analytics (Opcional)
ANALYTICS_SERVICE_URL=https://sua-api-aqui.com
ANALYTICS_SERVICE_ENDPOINT=/analises
BOT_API_KEY=sua-chave-aqui
